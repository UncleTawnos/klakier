{
  "project": {
    "name": "xml-prompt-generator",
    "description": "Web UI tool for generating XML-formatted prompts with configurable agents",
    "version": "1.0.0"
  },
  "architecture": {
    "overview": "Single-page React application with TypeScript, containerized with Docker, featuring a form-based UI that transforms user input into structured XML prompts",
    "principles": [
      "Separation of concerns between UI components and XML generation logic",
      "Configuration-driven agent management",
      "Real-time preview of generated XML",
      "Copy-to-clipboard functionality for easy prompt usage"
    ]
  },
  "projectStructure": {
    "directories": {
      "src/": "Source code root",
      "src/components/": "React components",
      "src/services/": "Business logic and XML generation",
      "src/types/": "TypeScript type definitions",
      "src/utils/": "Utility functions",
      "src/config/": "Configuration files",
      "src/styles/": "CSS/SCSS files",
      "public/": "Static assets",
      "docker/": "Docker configuration files",
      "tests/": "Test files"
    },
    "files": {
      "src/App.tsx": "Main application component",
      "src/index.tsx": "Application entry point",
      "src/components/AgentSelector.tsx": "Dropdown component for agent selection",
      "src/components/RequirementsInput.tsx": "Multi-line text input for requirements",
      "src/components/ContextInput.tsx": "Text input for context",
      "src/components/TaskInput.tsx": "Multi-line text input for task description",
      "src/components/XmlOutput.tsx": "Component to display formatted XML output",
      "src/components/CopyButton.tsx": "Button component for clipboard operations",
      "src/services/XmlGenerator.ts": "Service for converting inputs to XML format",
      "src/services/ConfigLoader.ts": "Service for loading agent configuration",
      "src/types/Agent.ts": "TypeScript interface for Agent",
      "src/types/PromptData.ts": "Interface for prompt form data",
      "src/utils/textParser.ts": "Utility for parsing paragraphs from text",
      "src/utils/clipboard.ts": "Clipboard operations utility",
      "src/config/agents.json": "Configuration file for available agents",
      "src/styles/App.css": "Main application styles",
      "docker/Dockerfile": "Docker image configuration",
      "docker/nginx.conf": "Nginx configuration for serving the app",
      "package.json": "Node.js dependencies and scripts",
      "tsconfig.json": "TypeScript configuration",
      "vite.config.ts": "Vite bundler configuration",
      ".dockerignore": "Docker ignore patterns",
      ".gitignore": "Git ignore patterns"
    }
  },
  "components": {
    "AgentSelector": {
      "purpose": "Dropdown/combobox for selecting configured agents",
      "props": {
        "agents": "Array of available agents from config",
        "selectedAgent": "Currently selected agent",
        "onAgentChange": "Callback when selection changes"
      },
      "features": [
        "Searchable dropdown",
        "Display agent name and description",
        "Default selection handling"
      ]
    },
    "RequirementsInput": {
      "purpose": "Multi-line text area for entering requirements",
      "props": {
        "value": "Current text value",
        "onChange": "Callback for text changes",
        "placeholder": "Placeholder text"
      },
      "features": [
        "Auto-resize based on content",
        "Paragraph detection for XML generation",
        "Character/paragraph count display"
      ]
    },
    "ContextInput": {
      "purpose": "Text area for entering context information",
      "props": {
        "value": "Current text value",
        "onChange": "Callback for text changes",
        "placeholder": "Placeholder text"
      },
      "features": [
        "Expandable text area",
        "Optional field indicator"
      ]
    },
    "TaskInput": {
      "purpose": "Multi-line text area for task description",
      "props": {
        "value": "Current text value",
        "onChange": "Callback for text changes",
        "placeholder": "Placeholder text"
      },
      "features": [
        "Paragraph-based input parsing",
        "Visual paragraph separation indicator"
      ]
    },
    "XmlOutput": {
      "purpose": "Display generated XML with syntax highlighting",
      "props": {
        "xmlContent": "Generated XML string",
        "isLoading": "Loading state indicator"
      },
      "features": [
        "Syntax highlighting for XML",
        "Line numbers",
        "Copy button integration",
        "Collapsible/expandable view"
      ]
    },
    "CopyButton": {
      "purpose": "Button to copy XML to clipboard",
      "props": {
        "content": "Text to copy",
        "onCopy": "Callback after successful copy"
      },
      "features": [
        "Visual feedback on copy",
        "Tooltip with status",
        "Keyboard shortcut support"
      ]
    }
  },
  "dataFlow": {
    "inputFlow": [
      "User selects agent from AgentSelector",
      "User enters requirements (paragraphs auto-detected)",
      "User enters optional context",
      "User enters task description (paragraphs auto-detected)",
      "Form data is collected in App.tsx state"
    ],
    "processingFlow": [
      "App.tsx passes form data to XmlGenerator service",
      "XmlGenerator parses paragraphs using textParser utility",
      "XmlGenerator constructs XML structure with nested elements",
      "Generated XML is returned to App.tsx"
    ],
    "outputFlow": [
      "XML string is passed to XmlOutput component",
      "XmlOutput renders formatted XML with syntax highlighting",
      "CopyButton allows copying XML to clipboard"
    ]
  },
  "configurationSchema": {
    "agents": {
      "type": "array",
      "description": "List of available agents",
      "items": {
        "id": "string - Unique identifier",
        "name": "string - Display name",
        "description": "string - Optional description",
        "xmlTag": "string - XML tag name for this agent",
        "attributes": "object - Optional XML attributes",
        "defaultContext": "string - Optional default context"
      }
    },
    "example": {
      "agents": [
        {
          "id": "assistant",
          "name": "AI Assistant",
          "description": "General-purpose AI assistant",
          "xmlTag": "assistant",
          "attributes": {
            "version": "1.0"
          }
        },
        {
          "id": "coder",
          "name": "Code Generator",
          "description": "Specialized coding assistant",
          "xmlTag": "coder",
          "attributes": {
            "language": "typescript"
          }
        }
      ]
    }
  },
  "xmlStructure": {
    "root": "<prompt>",
    "children": [
      {
        "element": "<agent>",
        "content": "Selected agent tag with attributes",
        "example": "<agent type=\"assistant\" version=\"1.0\"/>"
      },
      {
        "element": "<requirements>",
        "content": "Container for requirement items",
        "children": "<requirement> for each paragraph"
      },
      {
        "element": "<context>",
        "content": "Optional context information",
        "format": "Single element with text content"
      },
      {
        "element": "<task>",
        "content": "Container for task items",
        "children": "<task-item> for each paragraph"
      }
    ],
    "exampleOutput": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<prompt>\n  <agent type=\"assistant\" version=\"1.0\"/>\n  <requirements>\n    <requirement>First requirement paragraph</requirement>\n    <requirement>Second requirement paragraph</requirement>\n  </requirements>\n  <context>Optional context information</context>\n  <task>\n    <task-item>First task paragraph</task-item>\n    <task-item>Second task paragraph</task-item>\n  </task>\n</prompt>"
  },
  "dependencies": {
    "production": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "typescript": "^5.6.0",
      "vite": "^5.4.0",
      "clsx": "^2.1.0",
      "prism-react-renderer": "^2.3.0"
    },
    "development": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "@typescript-eslint/eslint-plugin": "^8.0.0",
      "@typescript-eslint/parser": "^8.0.0",
      "eslint": "^8.57.0",
      "eslint-plugin-react": "^7.34.0",
      "@vitejs/plugin-react": "^4.3.0",
      "sass": "^1.77.0"
    },
    "optional": {
      "react-select": "^5.8.0 - For enhanced dropdown functionality",
      "react-textarea-autosize": "^8.5.0 - For auto-resizing text areas",
      "react-hot-toast": "^2.4.0 - For toast notifications"
    }
  },
  "implementationPhases": {
    "phase1": {
      "name": "Project Setup",
      "duration": "2 hours",
      "tasks": [
        "Initialize React project with Vite and TypeScript",
        "Configure TypeScript with strict mode",
        "Set up project directory structure",
        "Install core dependencies",
        "Create Docker configuration files",
        "Set up ESLint and formatting rules"
      ]
    },
    "phase2": {
      "name": "Core Components",
      "duration": "4 hours",
      "tasks": [
        "Create base TypeScript interfaces (Agent, PromptData)",
        "Implement AgentSelector component with config loading",
        "Build RequirementsInput with paragraph detection",
        "Build ContextInput component",
        "Build TaskInput with paragraph detection",
        "Create basic App.tsx with state management"
      ]
    },
    "phase3": {
      "name": "XML Generation",
      "duration": "3 hours",
      "tasks": [
        "Implement textParser utility for paragraph splitting",
        "Create XmlGenerator service with proper formatting",
        "Add XML validation logic",
        "Implement special character escaping",
        "Create unit tests for XML generation"
      ]
    },
    "phase4": {
      "name": "Output and Polish",
      "duration": "3 hours",
      "tasks": [
        "Implement XmlOutput component with syntax highlighting",
        "Add CopyButton with clipboard functionality",
        "Style components with CSS/SCSS",
        "Add loading states and error handling",
        "Implement keyboard shortcuts",
        "Add accessibility features (ARIA labels)"
      ]
    },
    "phase5": {
      "name": "Docker and Deployment",
      "duration": "2 hours",
      "tasks": [
        "Create multi-stage Dockerfile",
        "Configure nginx for static hosting",
        "Set up docker-compose for local development",
        "Add environment variable support",
        "Create build scripts",
        "Test containerized application"
      ]
    },
    "phase6": {
      "name": "Testing and Documentation",
      "duration": "2 hours",
      "tasks": [
        "Write unit tests for utilities",
        "Add component tests",
        "Create integration tests for XML generation",
        "Write README with usage instructions",
        "Document configuration schema",
        "Add example agent configurations"
      ]
    }
  },
  "dockerSetup": {
    "dockerfile": {
      "strategy": "Multi-stage build",
      "stages": [
        {
          "name": "builder",
          "base": "node:20-alpine",
          "purpose": "Build the application",
          "steps": [
            "Copy package files",
            "Install dependencies",
            "Copy source code",
            "Run build command"
          ]
        },
        {
          "name": "production",
          "base": "nginx:alpine",
          "purpose": "Serve the application",
          "steps": [
            "Copy built files from builder",
            "Copy nginx configuration",
            "Expose port 80",
            "Start nginx"
          ]
        }
      ]
    },
    "dockerCompose": {
      "services": {
        "app": {
          "build": "./",
          "ports": "3000:80",
          "volumes": "./src/config:/usr/share/nginx/html/config",
          "environment": {
            "NODE_ENV": "production"
          }
        }
      }
    },
    "commands": {
      "build": "docker build -t xml-prompt-generator .",
      "run": "docker run -p 3000:80 -v $(pwd)/src/config:/usr/share/nginx/html/config xml-prompt-generator",
      "compose": "docker-compose up -d"
    }
  },
  "errorHandling": {
    "strategies": [
      "Graceful fallback for missing agent configuration",
      "Input validation before XML generation",
      "Error boundaries for React components",
      "Toast notifications for user feedback",
      "Clipboard API fallback for older browsers"
    ],
    "validations": [
      "Required field validation (agent, task)",
      "XML special character escaping",
      "Maximum character limits for inputs",
      "Configuration file format validation"
    ]
  },
  "performanceOptimizations": [
    "Debounced XML generation on input changes",
    "Memoized component renders with React.memo",
    "Lazy loading of syntax highlighting library",
    "Virtual scrolling for large XML outputs",
    "Cached agent configuration"
  ],
  "futureEnhancements": [
    "Save/load prompt templates",
    "Multiple output format support (JSON, YAML)",
    "Dark mode toggle",
    "Export history of generated prompts",
    "Custom XML schema definitions",
    "Collaborative editing features",
    "API endpoint for programmatic generation"
  ]
}